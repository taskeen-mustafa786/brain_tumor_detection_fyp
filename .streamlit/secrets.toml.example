# Firebase Configuration for Streamlit Cloud
# Add these secrets in your Streamlit Cloud dashboard under "Secrets"

# Firebase Web API Configuration
FIREBASE_API_KEY = "your_firebase_api_key_here"
FIREBASE_AUTH_DOMAIN = "your_project.firebaseapp.com"
FIREBASE_PROJECT_ID = "your_project_id"
FIREBASE_STORAGE_BUCKET = "your_project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID = "123456789"
FIREBASE_APP_ID = "1:123456789:web:abcdef123456"

# Firestore Database URL
FIREBASE_DATABASE_URL = "https://your_project.firebaseio.com"

# Firebase Admin SDK (for server-side operations)
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PRIVATE_KEY_ID = "your_private_key_id"
FIREBASE_PRIVATE_KEY = "-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL = "firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com"
FIREBASE_CLIENT_ID = "your_client_id"
FIREBASE_CLIENT_X509_CERT_URL = "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your_project.iam.gserviceaccount.com"

# Application Settings
APP_ENV = "production"
DEBUG = "false"

# JWT Secret for authentication
JWT_SECRET = "your_secure_jwt_secret_here"

# Model Configuration
MODEL_PATH = "TL-Model/TL_btd_model.h5"
CONFIDENCE_THRESHOLD = "0.7"